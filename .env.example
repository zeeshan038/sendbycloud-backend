# App
PORT=8080
BACKEND_URL=http://localhost:8080
CLIENT_URL=http://localhost:5173

# Database
MONGODB_URI=mongodb://localhost:27017/sendbycloud

# R2 Configuration
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_FOLDER= # Optional

# Download Proxy (Cloudflare Worker)
# If set, high-performance multipart downloads will go through this worker.
# Example: https://download.sendbycloud.com
DOWNLOAD_PROXY_URL=

# Nodemailer
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# JWT
JWT_SECRET=your_jwt_secret
